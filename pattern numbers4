import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        
        if (!scanner.hasNextInt()) {
            scanner.close();
            return;
        }
        
        int n = scanner.nextInt();
        int currentNumber = 1;
        
        for (int i = 1; i <= n; i++) {
            for (int j = 1; j <= i; j++) {
                System.out.print(currentNumber);
                if (j < i) {
                    System.out.print(" ");
                }
                currentNumber++;
            }
            System.out.println();
        }
        
        scanner.close();
    }
}
